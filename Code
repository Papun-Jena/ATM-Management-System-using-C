#include <stdio.h>

int main()
{
    int pin = 123456;
    int enteredPin;
    int choice;
    int amount;
    int balance = 10000;
    int attempts = 3;

    while (attempts > 0)
    {
        printf("Enter PIN: ");
        scanf("%d", &enteredPin);

        if (enteredPin == pin)
        {
            printf("\nLogin Successful\n");

            do
            {
                printf("\n===== ATM MENU =====\n");
                printf("1. Check Balance\n");
                printf("2. Withdraw Cash\n");
                printf("3. Deposit Cash\n");
                printf("4. Exit\n");
                printf("====================\n");
                printf("Enter Choice: ");
                scanf("%d", &choice);

                switch (choice)
                {
                    case 1:
                        printf("\nCurrent Balance: Rs.%d\n", balance);
                        break;

                    case 2:
                        printf("\nEnter Amount To Withdraw: ");
                        scanf("%d", &amount);

                        if (amount <= 0)
                        {
                            printf("Invalid Amount\n");
                        }
                        else if (amount > balance)
                        {
                            printf("Insufficient Balance\n");
                        }
                        else if (amount % 100 != 0)
                        {
                            printf("Amount Must Be Multiple Of 100\n");
                        }
                        else
                        {
                            balance -= amount;
                            printf("Withdrawal Successful\n");
                            printf("Remaining Balance: Rs.%d\n", balance);
                        }
                        break;

                    case 3:
                        printf("\nEnter Amount To Deposit: ");
                        scanf("%d", &amount);

                        if (amount <= 0)
                        {
                            printf("Invalid Amount\n");
                        }
                        else
                        {
                            balance += amount;
                            printf("Deposit Successful\n");
                            printf("Updated Balance: Rs.%d\n", balance);
                        }
                        break;

                    case 4:
                        printf("\nThank You For Using Our ATM\n");
                        break;

                    default:
                        printf("\nInvalid Choice\n");
                }

            } while (choice != 4);

            return 0;
        }
        else
        {
            attempts--;
            printf("Incorrect PIN\n");

            if (attempts > 0)
            {
                printf("Attempts Remaining: %d\n", attempts);
            }
        }
    }

    printf("\nCard Blocked Due To Multiple Invalid Attempts\n");

    return 0;
}